# Leave unset for local development - axiosClient.js and socketClient.js
# fall back to a relative path, which Vite's dev server proxy
# (see vite.config.js) forwards to http://localhost:5000.
#
# In Vercel (Project Settings > Environment Variables), set this to your
# Render backend's URL with NO trailing slash, e.g.:
#   VITE_API_URL=https://learncs01-api.onrender.com
VITE_API_URL=
