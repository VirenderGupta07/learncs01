# ====== CORE ======
NODE_ENV=development
PORT=5000
# Leave unset on Render - it's auto-filled from RENDER_EXTERNAL_URL. Only set
# this explicitly for local dev or non-Render hosts.
API_PUBLIC_URL=http://localhost:5000
CLIENT_URLS=http://localhost:5173,http://localhost:19006

# Set to true to run the certificate-generation worker inside this same
# process instead of as a separate service. Intended for free-tier hosts
# (e.g. Render's Hobby plan) that don't offer a free Background Worker
# instance type - see DEPLOYMENT.md. Leave false/unset for a real production
# deployment with a dedicated `npm run worker` process.
RUN_WORKER_INLINE=false

# ====== DATABASE ======
MONGO_URI=mongodb://127.0.0.1:27017/learncs01

# ====== AUTH / JWT ======
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# ====== STRIPE (global payments) ======
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ====== SSLCOMMERZ (regional payments) ======
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false
# Comma-separated IP allowlist for inbound IPN requests.
# SSLCommerz does not publish one fixed list publicly - obtain the current
# source IP(s) from SSLCommerz merchant support/docs and set them here.
# This is defense-in-depth on top of the mandatory val_id server validation
# call already performed in services/sslcommerzPayment.service.js.
SSLCOMMERZ_ALLOWED_IPS=

# ====== AWS S3 (admin-uploaded lecture videos + certificates) ======
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=learncs01-media
AWS_CLOUDFRONT_DOMAIN=

# ====== REDIS (BullMQ background jobs + socket scaling) ======
REDIS_URL=redis://127.0.0.1:6379

# ====== EMAIL (SMTP) ======
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@learncs01.com
